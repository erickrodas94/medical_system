<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /medical_system

    # Si el archivo o carpeta física existe, úsalo directamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Si no existe, manda todo a public/index.php
    RewriteRule ^(.*)$ public/index.php?url=$1 [QSA,L]
</IfModule>